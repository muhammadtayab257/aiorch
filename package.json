{
  "name": "aiorch",
  "version": "1.0.0",
  "description": "Unified interface for OpenAI, Anthropic, and Gemini APIs with automatic fallback, retry logic, cost tracking, and logging.",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "scripts": {
    "start": "node examples/basic-usage.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build:types": "tsc",
    "prepublishOnly": "npm test && npm run build:types"
  },
  "keywords": [
    "ai",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "llm",
    "fallback",
    "retry",
    "cost-tracking",
    "unified-api"
  ],
  "author": "Neha Thakur <neha.thakur@identifymobile.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muhammadtayab257/aiorch.git"
  },
  "bugs": {
    "url": "https://github.com/muhammadtayab257/aiorch/issues"
  },
  "homepage": "https://github.com/muhammadtayab257/aiorch#readme",
  "files": [
    "src/",
    "types/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.67.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
